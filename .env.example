# WaveFlow environment template — copy to .env and fill in values.

# Postgres (audit trail, idempotency)
DATABASE_URL=postgres://waveflow:waveflow@localhost:5433/waveflow

# Soroban / Stellar
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015
ESCROW_CONTRACT_ID=
GATEWAY_SECRET_KEY=

# GitHub webhook verification
WAVEFLOW_ENV=development
GITHUB_WEBHOOK_SECRET=change-me-to-github-webhook-secret

# API authentication (comma-separated admin keys)
API_ADMIN_KEYS=dev-admin-key-change-in-production

# Service ports (Render sets PORT automatically)
GATEWAY_PORT=8080
API_PORT=8081
PORT=8080

# Observability
RUST_LOG=info,waveflow_gateway=debug,waveflow_api=debug
OTEL_EXPORTER_OTLP_ENDPOINT=
